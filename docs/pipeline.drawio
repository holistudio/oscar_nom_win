        <mxCell id="pq0AM1h1IiiyBDEnBlEK-52" value="Downloads the weights/parameters from OpenAI&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;load weights function uses TensorFlow&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1">
