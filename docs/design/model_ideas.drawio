        <mxCell id="HTBFFHoUUt1TWve2A3QG-150" value="Are you planning to freeze GPT-2 entirely, or did you want to experiment with end-to-end fine-tuning through the whole pipeline?&amp;nbsp;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="1585" y="763" width="164" height="87" as="geometry" />
        </mxCell>
        <mxCell id="HTBFFHoUUt1TWve2A3QG-151" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Chunky GPT-2 + Transformer Decoder&lt;/h1&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;(the alternative TransformerEncoder =&amp;gt; GPT-2 =&amp;gt; probability is possible but is architecturally similar to TransfomerEncoder=&amp;gt;Decoder, especially if the GPT-2 here is untrained and weights a trainable)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;(using a pre-trained GPT-2 as decoder also makes little sense since it was never trained to interpret sequences of embeddings)&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1485" y="195" width="312" height="219" as="geometry" />
