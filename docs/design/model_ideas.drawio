        <mxCell id="b7kDbyQH0VOEQEVwCjPc-234" value="when creating Dataset, sequences are padded such that all screenplays have the same seq_len" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacing=0;spacingRight=4;" parent="1" vertex="1">
