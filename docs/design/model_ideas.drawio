        <mxCell id="itTbuPaQ1f0lpQnEGbCo-603" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Step 1: Tokenize and Padding&lt;/h1&gt;&lt;p&gt;Screenplays are tokenized using GPT-2 encoding&lt;/p&gt;&lt;p&gt;Based on the maximum token length among all screenplays (train/val/test) shorter screenplays are padded with zeros.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-569" y="4720" width="360" height="140" as="geometry" />
        </mxCell>
        <mxCell id="itTbuPaQ1f0lpQnEGbCo-604" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Step 2: Reshape and Merge&lt;/h1&gt;&lt;p&gt;Screenplay token sequences are reshaped based on chunk_size and then merged into a single block before fed to the model.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-718" y="5240" width="360" height="140" as="geometry" />
