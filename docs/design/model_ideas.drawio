        <mxCell id="itTbuPaQ1f0lpQnEGbCo-1208" value="then, depending on chunk_size, sequences are all padded to the same length again to ensure that the seq_len is a multiple of chunk_size" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacing=0;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="2221" y="4810" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="itTbuPaQ1f0lpQnEGbCo-1209" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Step 3: Aggregate and Classify&lt;/h1&gt;&lt;p&gt;Now that the screenplays are sequence of encoded vectors, each screenplay is now a matrix of shape (num_chunks, encoder_dim), another transformer attempts to represent that as one vector of numbers before a linear layer projects it to logits for classification.&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="9241" y="4990" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="itTbuPaQ1f0lpQnEGbCo-1210" value="so it makes sense that last element of the each chunk has accumulated the most information" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacing=0;spacingRight=4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="5162" y="5488" width="199" height="80" as="geometry" />
        </mxCell>
        <mxCell id="itTbuPaQ1f0lpQnEGbCo-1211" value="it makes sense to then only focus on the &quot;last slice&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacing=0;spacingRight=4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="6391" y="5828.33" width="169" height="40" as="geometry" />
        </mxCell>
        <mxCell id="itTbuPaQ1f0lpQnEGbCo-1212" value="it makes sense to then only focus on the &quot;last slice&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacing=0;spacingRight=4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="12281" y="5653.33" width="169" height="40" as="geometry" />
        </mxCell>
        <mxCell id="itTbuPaQ1f0lpQnEGbCo-1213" value="unlike above, a causal mask is applied so that outputs can only attend to previous rows.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;same as the previous step&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacing=0;spacingRight=4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="11221" y="5665" width="199" height="95" as="geometry" />
        </mxCell>
        <mxCell id="xo3a8JR-aOrW4SpTwfVp-1" value="" style="shape=cube;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;darkOpacity=0.05;darkOpacity2=0.1;size=30;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
