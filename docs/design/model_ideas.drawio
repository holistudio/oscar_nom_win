        <mxCell id="HTBFFHoUUt1TWve2A3QG-128" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Brute Force Transformer&lt;/h1&gt;&lt;div&gt;Similar to above.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&quot;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;With 100k tokens, you&#39;re looking at attention weight matrices of shape (100k, 100k) — that&#39;s 10 billion floating-point values per head.&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;More precisely, the issue is not the higher-level architecture here (see above architectures that do involve TransformerEncoder+Decoder). The issue is the fact that we are expecting something to process the entire +30k movie script tokens all in one shot.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Instead we need to process the long token sequence &quot;chunk by chunk&quot;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="64" y="2335" width="312" height="263" as="geometry" />
        </mxCell>
        <mxCell id="HTBFFHoUUt1TWve2A3QG-130" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="HTBFFHoUUt1TWve2A3QG-129" target="HTBFFHoUUt1TWve2A3QG-72" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="HTBFFHoUUt1TWve2A3QG-129" value="movie_script.txt" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-116" y="2075.5" width="123" height="71" as="geometry" />
        </mxCell>
        <mxCell id="HTBFFHoUUt1TWve2A3QG-131" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Chunky Transformer Encoder-Decoder&lt;/h1&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
