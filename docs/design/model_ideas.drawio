        <mxCell id="5YeFSjLjMYRp-iu9aZjN-30" value="Sebastian Raschka&#39;s LLM from Scratch book modifies the GPT-2 to be a classifier by replacing the last linear layer." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="836" y="2256" width="207" height="92" as="geometry" />
        </mxCell>
        <mxCell id="5YeFSjLjMYRp-iu9aZjN-31" value="Even though it is a binary classifier, the output size is set to 2 so that the ordinary Cross Entropy Loss function can be used, same as what GPT-2 used. Raschka found issues if the loss function is switched from CrossEntropy to BCE." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1638" y="2263" width="207" height="116" as="geometry" />
        </mxCell>
        <mxCell id="5YeFSjLjMYRp-iu9aZjN-32" value="Regardless, the attention memory issue is still there!" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
