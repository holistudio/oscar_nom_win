{
  "model": {
    "module": "mean_agg",
    "class_name": "OscarNomAgg",
    "params": {
      "chunk_size": 1024,
      "enc_d_model": 768,
      "agg_d_model": 256,
      "agg_nhead": 8,
      "agg_num_layers": 4,
      "max_seq_len": 106578,
      "dropout": 0.25
    }
