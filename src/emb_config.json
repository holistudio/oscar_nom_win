      1.0,
      8.0
    ],
    "label_smoothing": 0.1,
    "seed": 1337,
    "checkpoint_prefix": "best_gpt_agg",
    "models_dir": "../models",
    "results_dir": "../results",
    "sub_dir": "best_results",
    "history_filename": "training_history.json"
  },
  "data": {
    "embed_dir": "./gpt2_embed",
    "eager_load": true,
    "subsample": null
  },
  "wandb": {
    "enabled": true,
    "project": "oscar_nom_win",
    "entity": null,
    "mode": "offline",
    "name": null,
    "tags": [
      "gpt2_emb_frozen",
      "causal_enc",
      "bidir_agg",
      "enc_d_768",
      "enc_nhead_12",
      "enc_l_12",
      "agg_d_256",
      "agg_nhead_8",
      "agg_l_4"
